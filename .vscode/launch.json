{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Sensor",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-sensor",
            "program": "${workspaceFolder}/src/Sensor/bin/Debug/net9.0/Sensor.dll",
            "args": ["127.0.0.1", "5000", "sensor-01"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
            }
        },
        {
            "name": "Debug Gateway",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-gateway",
            "program": "${workspaceFolder}/src/Gateway/bin/Debug/net9.0/Gateway.dll",
            "args": ["5000", "127.0.0.1:6000", "${workspaceFolder}/sensores.csv"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
            }
        },
        {
            "name": "Debug Sensor (Remote Gateway)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-sensor",
            "program": "${workspaceFolder}/src/Sensor/bin/Debug/net9.0/Sensor.dll",
            "args": ["${input:gatewayIp}", "${input:gatewayPort}", "${input:sensorId}"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
            }
        },
        {
            "name": "Run Tests (SharedProtocol)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-tests",
            "program": "${workspaceFolder}/tests/SharedProtocol.Tests/bin/Debug/net9.0/SharedProtocol.Tests.dll",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Run Tests (Sensor)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-tests-sensor",
            "program": "${workspaceFolder}/tests/Sensor.Tests/bin/Debug/net9.0/Sensor.Tests.dll",
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        }
    ],
    "inputs": [
        {
            "id": "gatewayIp",
            "type": "promptString",
            "description": "Gateway IP address",
            "default": "127.0.0.1"
        },
        {
            "id": "gatewayPort",
            "type": "promptString",
            "description": "Gateway port",
            "default": "5000"
        },
        {
            "id": "sensorId",
            "type": "promptString",
            "description": "Sensor ID",
            "default": "sensor-01"
        }
    ]
}
