FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src
COPY src/SharedProtocol/SharedProtocol.csproj SharedProtocol/
COPY src/Servidor/Servidor.csproj Servidor/
RUN dotnet restore Servidor/Servidor.csproj
COPY src/SharedProtocol/ SharedProtocol/
COPY src/Servidor/ Servidor/
RUN dotnet publish Servidor/Servidor.csproj -c Release -o /app

FROM mcr.microsoft.com/dotnet/runtime:9.0
WORKDIR /app
COPY --from=build /app .
EXPOSE 7000
ENTRYPOINT ["dotnet", "Servidor.dll"]
